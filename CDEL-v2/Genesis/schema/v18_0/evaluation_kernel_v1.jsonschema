{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis.engine/specs/v18_0/evaluation_kernel_v1",
  "title": "CCAP evaluation kernel v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ek_version",
    "obs_schema_ids",
    "obs_canon_id",
    "boundary_event_set_id",
    "stages",
    "scoring_impl"
  ],
  "properties": {
    "schema_version": {"const": "evaluation_kernel_v1"},
    "ek_version": {"type": "integer", "minimum": 0, "maximum": 4294967295},
    "obs_schema_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "obs_canon_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "boundary_event_set_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/stage_spec"}
    },
    "scoring_impl": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "code_ref",
        "applicability_preds_id",
        "ek_meta_tests_id"
      ],
      "properties": {
        "kind": {"const": "OMEGA_BENCHMARK_SUITE"},
        "code_ref": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "commit_hash",
            "path"
          ],
          "properties": {
            "commit_hash": {"type": "string", "minLength": 7},
            "path": {"type": "string", "minLength": 1}
          }
        },
        "accept_policy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "stps_delta_min_q32": {"type": "integer", "minimum": 0},
            "require_any_improvement_b": {"type": "boolean"},
            "ticks_u64": {"type": "integer", "minimum": 1}
          }
        },
        "applicability_preds_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "ek_meta_tests_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      }
    }
  },
  "$defs": {
    "stage_spec": {
      "$anchor": "StageSpec",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_name"
      ],
      "properties": {
        "stage_name": {
          "type": "string",
          "enum": [
            "REALIZE",
            "SCORE",
            "FINAL_AUDIT"
          ]
        },
        "required_b": {"type": "boolean", "default": true},
        "hard_gate_b": {"type": "boolean", "default": true},
        "timeout_ms_max_u64": {"type": "integer", "minimum": 0}
      }
    }
  }
}
