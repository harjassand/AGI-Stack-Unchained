{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis.engine/specs/v18_0/omega_activation_receipt_v1",
  "title": "Omega activation receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "tick_u64",
    "before_active_manifest_hash",
    "after_active_manifest_hash",
    "healthcheck_suite_hash",
    "healthcheck_result",
    "activation_method",
    "activation_success",
    "pass",
    "reasons"
  ],
  "properties": {
    "schema_version": {"const": "omega_activation_receipt_v1"},
    "receipt_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "tick_u64": {"type": "integer", "minimum": 0},
    "before_active_manifest_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "after_active_manifest_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "healthcheck_suite_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "healthcheck_result": {"type": "string", "enum": ["PASS", "FAIL"]},
    "activation_method": {
      "type": "string",
      "enum": ["ATOMIC_POINTER_SWAP", "ACTIVATION_KIND_EXT_QUEUED", "ACTIVATION_KIND_ORCH_POLICY_UPDATE"]
    },
    "activation_kind": {
      "type": "string",
      "enum": ["ATOMIC_POINTER_SWAP", "ACTIVATION_KIND_EXT_QUEUED", "ACTIVATION_KIND_ORCH_POLICY_UPDATE"]
    },
    "activation_success": {"type": "boolean"},
    "pass": {"type": "boolean"},
    "extension_queued_receipt_hash": {
      "anyOf": [
        {"type": "null"},
        {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      ]
    },
    "extension_queued_status_code": {
      "anyOf": [
        {"type": "null"},
        {
          "type": "string",
          "enum": [
            "ACT_EXT_QUEUED:OK",
            "ACT_EXT_QUEUED:WRITE_FAIL",
            "ACT_EXT_QUEUED:HASH_MISMATCH"
          ]
        }
      ]
    },
    "orch_policy_activation_receipt_hash": {
      "anyOf": [
        {"type": "null"},
        {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      ]
    },
    "orch_policy_pointer_path": {
      "anyOf": [
        {"type": "null"},
        {"type": "string", "minLength": 1}
      ]
    },
    "native_runtime_contract_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "native_healthcheck_vectors_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "native_restricted_ir_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "native_src_merkle_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "native_build_proof_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "native_shadow_registry_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "native_module": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": [
        "op_id",
        "abi_version_u32",
        "abi_kind",
        "language",
        "platform",
        "binary_sha256",
        "source_manifest_hash",
        "vendor_manifest_hash",
        "build_receipt_hash",
        "hotspot_report_hash",
        "toolchain_manifest_hash",
        "healthcheck_receipt_hash",
        "bench_report_hash"
      ],
      "properties": {
        "op_id": {"type": "string", "minLength": 1},
        "abi_version_u32": {"const": 1},
        "abi_kind": {"const": "BLOBLIST_V1"},
        "language": {"const": "RUST"},
        "platform": {"type": "string", "minLength": 1},
        "binary_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "source_manifest_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "vendor_manifest_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "build_receipt_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "hotspot_report_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "toolchain_manifest_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "healthcheck_receipt_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "bench_report_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      }
    },
    "native_activation_gate_result": {"type": ["string", "null"], "enum": ["PASS", "FAIL", "SKIP", null]},
    "native_gate_reason": {
      "type": ["string", "null"],
      "enum": [
        "NATIVE_GATE_PASS",
        "NATIVE_GATE_BINARY_MISSING",
        "NATIVE_GATE_BINARY_HASH_MISMATCH",
        "NATIVE_GATE_DLOPEN_FAIL",
        "NATIVE_GATE_ABI_MISMATCH",
        "NATIVE_GATE_OP_ID_MISMATCH",
        "NATIVE_GATE_HEALTHCHECK_FAIL",
        null
      ]
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "HEALTHCHECK_PASS",
          "HEALTHCHECK_FAIL",
          "POINTER_SWAP_FAILED",
          "META_CORE_DENIED",
          "BINDING_MISSING_OR_MISMATCH",
          "ROLLBACK_REQUIRED",
          "NATIVE_GATE_REQUIRED",
          "NATIVE_GATE_FAILED",
          "EXTENSION_QUEUED",
          "ACT_EXT_QUEUED:OK",
          "ACT_EXT_QUEUED:WRITE_FAIL",
          "ACT_EXT_QUEUED:HASH_MISMATCH",
          "ORCH_POLICY_POINTER_UPDATED",
          "ORCH_POLICY_POINTER_UPDATE_FAILED"
        ]
      }
    }
  }
}
