{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis.engine/specs/v18_0/qxrl_eval_manifest_v1",
  "title": "qxrl_eval_manifest_v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "qxrl_eval_manifest_v1"},
    "eval_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},

    "opset_id": {"type": "string", "pattern": "^opset:eudrs_u_v1:sha256:[0-9a-f]{64}$"},
    "dc1_id": {"type": "string", "const": "dc1:q32_v1"},

    "model_manifest_ref": {"$ref": "https://genesis.engine/specs/v18_0/eudrs_u_artifact_ref_v1"},
    "dataset_manifest_ref": {"$ref": "https://genesis.engine/specs/v18_0/eudrs_u_artifact_ref_v1"},

    "dot_kind": {"type": "string", "enum": ["DOT_Q32_SHIFT_END_V1", "DOT_Q32_SHIFT_EACH_DIM_V1"]},

    "eval_example_count_u32": {"type": "integer", "minimum": 1, "maximum": 4294967295},
    "eval_start_index_u64": {"type": "integer", "minimum": 0},

    "mask_prob_q32": {
      "type": "object",
      "additionalProperties": false,
      "properties": {"q": {"type": "integer", "minimum": 0}},
      "required": ["q"]
    },
    "max_masks_per_seq_u32": {"type": "integer", "minimum": 0, "maximum": 4294967295},
    "mlm_neg_k_u32": {"type": "integer", "minimum": 1, "maximum": 4294967295},
    "NEG_RESAMPLE_CAP_u32": {"type": "integer", "minimum": 0, "maximum": 4294967295},

    "recall_k_u32": {"type": "integer", "minimum": 1, "maximum": 4294967295},
    "floors": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "masked_acc_at_1_min_q32": {
          "type": "object",
          "additionalProperties": false,
          "properties": {"q": {"type": "integer", "minimum": 0}},
          "required": ["q"]
        },
        "recall_at_k_min_q32": {
          "type": "object",
          "additionalProperties": false,
          "properties": {"q": {"type": "integer", "minimum": 0}},
          "required": ["q"]
        }
      },
      "required": ["masked_acc_at_1_min_q32", "recall_at_k_min_q32"]
    },

    "checks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "collapse_check_enabled": {"type": "boolean"},
        "drift_check_enabled": {"type": "boolean"}
      },
      "required": ["collapse_check_enabled", "drift_check_enabled"]
    },

    "scorecard_ref": {"$ref": "https://genesis.engine/specs/v18_0/eudrs_u_artifact_ref_v1"}
  },
  "required": [
    "schema_id",
    "eval_id",
    "opset_id",
    "dc1_id",
    "model_manifest_ref",
    "dataset_manifest_ref",
    "dot_kind",
    "eval_example_count_u32",
    "eval_start_index_u64",
    "mask_prob_q32",
    "max_masks_per_seq_u32",
    "mlm_neg_k_u32",
    "NEG_RESAMPLE_CAP_u32",
    "recall_k_u32",
    "floors",
    "checks",
    "scorecard_ref"
  ]
}

