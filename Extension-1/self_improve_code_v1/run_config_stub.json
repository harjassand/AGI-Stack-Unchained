    "beta": 0,
    "eta": 1,
    "A": 1,
    "B1": 0,
    "B2": 0,
    "R": 1000000
  },
  "devscreen": {
    "cwd": ".",
    "argv": [
      "python3",
      "devscreen/stub_devscreen_v1.py",
      "--seed",
      "{seed}",
      "--out_dir",
      "{out_dir}"
    ],
    "env": {
      "PYTHONHASHSEED": "0",
      "LC_ALL": "C",
      "TZ": "UTC"
    },
    "metric": {
      "file_relpath": "ceiling_ladder_summary.json",
      "json_pointer": "/pass_rates/dev/C"
    }
  },
  "cdel": {
    "backend": "stub_v1",
    "cwd": ".",
    "argv": [
      "python3",
      "cdel/stub_cdel_v1.py",
      "--candidate",
      "{candidate_tar}",
      "--out_dir",
      "{out_dir}"
    ],
    "env": {
      "PYTHONHASHSEED": "0",
      "LC_ALL": "C",
      "TZ": "UTC"
    }
  },
  "candidate_id": {
    "backend": "stub_deterministic_v1"
  }
