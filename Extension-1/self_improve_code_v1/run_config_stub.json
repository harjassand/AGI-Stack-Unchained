{
  "format": "self_improve_code_run_config_v1",
  "schema_version": "1",
  "seed": 123,
  "eval_plan_id": "stub_eval_plan",
  "target_repo": {
    "repo_id": "agi-system",
    "repo_root": "../../agi-system",
    "baseline_commit": "REPLACE_WITH_40_HEX_FROM: git -C ../agi-system rev-parse HEAD"
  },
  "workspace": {
    "materialize": "git_archive_v1",
    "repo_root": "../../agi-system"
  },
  "arms_file": "targets/arms_stub_v1.json",
  "search": {
    "budget_candidates": 2,
    "max_edit_set_size": 1,
    "max_token_spans_per_file": 1,
