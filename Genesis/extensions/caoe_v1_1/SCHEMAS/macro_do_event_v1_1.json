{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "macro_do_event_v1_1",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "schema_version", "events"],
  "properties": {
    "format": {"const": "macro_do_event_v1_1"},
    "schema_version": {"const": 1},
    "events": {
      "type": "array",
      "items": {"$ref": "#/$defs/event"}
    }
  },
  "$defs": {
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["t", "set"],
      "properties": {
        "t": {"type": "integer", "minimum": 0},
        "set": {
          "type": "object",
          "additionalProperties": {"type": "integer", "enum": [0, 1]}
        }
      }
    }
  }
}
