{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis.engine/specs/ccai_x_v1/ccai_x_mind_patch_candidate_manifest_v1.schema.json",
  "title": "CCAI-X v1 Mind Patch Candidate Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "schema_version",
    "task_id",
    "candidate_id",
    "artifacts"
  ],
  "properties": {
    "format": {"const": "ccai_x_mind_patch_candidate_manifest_v1"},
    "schema_version": {"const": "1"},
    "task_id": {"const": "ccai_x_v1"},
    "candidate_id": {"$ref": "#/$defs/hash"},
    "artifacts": {
      "type": "array",
      "items": {"$ref": "#/$defs/artifact"},
      "uniqueItems": true
    },
    "x_extensions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    }
  },
  "$defs": {
    "hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "bytes_len"],
      "properties": {
        "path": {
          "type": "string",
          "enum": [
            "mechanism_registry.json",
            "policy_prior.json",
            "preference_capsule.json",
            "inference_kernel_isa.json",
            "markov_blanket_spec.json",
            "do_map.json"
          ]
        },
        "sha256": {"$ref": "#/$defs/hash"},
        "bytes_len": {"type": "integer", "minimum": 1}
      }
    }
  }
}
