{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis.engine/specs/v10_0/model_eval_receipt_v1",
  "title": "Model eval receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_id",
    "math_metric",
    "science_metric",
    "safety_metric",
    "meets_thresholds",
    "sealed_eval_receipt_hashes"
  ],
  "properties": {
    "schema_version": {
      "const": "model_eval_receipt_v1"
    },
    "bundle_id": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "math_metric": {
      "type": "object",
      "required": [
        "num",
        "den"
      ],
      "properties": {
        "num": {
          "type": "integer"
        },
        "den": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "science_metric": {
      "type": "object",
      "required": [
        "num",
        "den"
      ],
      "properties": {
        "num": {
          "type": "integer"
        },
        "den": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "safety_metric": {
      "type": "object",
      "required": [
        "num",
        "den"
      ],
      "properties": {
        "num": {
          "type": "integer"
        },
        "den": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "meets_thresholds": {
      "type": "boolean"
    },
    "sealed_eval_receipt_hashes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^sha256:[0-9a-f]{64}$"
      }
    }
  }
}
