{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis.engine/specs/v11_0/sas_model_eval_receipt_heldout_v1",
  "title": "SAS model eval receipt heldout v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "arch_id",
    "arch_graph_hash",
    "weights_sha256",
    "param_count",
    "primary_metric_name",
    "primary_metric_direction",
    "primary_metric_q32",
    "utility_q32",
    "param_penalty_exponent",
    "param_penalty_q32",
    "capacity_efficiency_q32",
    "eval_config_hash",
    "dataset_path",
    "toolchain_hash",
    "stdout_hash",
    "stderr_hash",
    "time_ms",
    "network_used"
  ],
  "properties": {
    "schema_version": {"const": "sas_model_eval_receipt_heldout_v1"},
    "arch_id": {"type": "string"},
    "arch_graph_hash": {"type": "string"},
    "weights_sha256": {"type": "string"},
    "param_count": {"type": "integer"},
    "primary_metric_name": {"type": "string"},
    "primary_metric_direction": {"enum": ["higher_is_better", "lower_is_better"]},
    "primary_metric_q32": {"$ref": "q32_v1.jsonschema"},
    "utility_q32": {"$ref": "q32_v1.jsonschema"},
    "param_penalty_exponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["num", "den"],
      "properties": {"num": {"type": "integer"}, "den": {"type": "integer"}}
    },
    "param_penalty_q32": {"$ref": "q32_v1.jsonschema"},
    "capacity_efficiency_q32": {"$ref": "q32_v1.jsonschema"},
    "eval_config_hash": {"type": "string"},
    "dataset_path": {"type": "string"},
    "toolchain_hash": {"type": "string"},
    "stdout_hash": {"type": "string"},
    "stderr_hash": {"type": "string"},
    "time_ms": {"type": "integer"},
    "network_used": {"type": "boolean"}
  }
}
