{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis.engine/specs/v11_0/sas_math_eval_report_v1",
  "title": "SAS-MATH eval report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_id",
    "eval_kind",
    "attempt_count",
    "pass_count",
    "total_wall_ms",
    "utility_q32",
    "capacity_eff_q32",
    "pass_problem_ids",
    "attempt_receipt_hashes"
  ],
  "properties": {
    "schema_version": {"const": "sas_math_eval_report_v1"},
    "policy_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "eval_kind": {"type": "string", "enum": ["DEV", "HELDOUT"]},
    "attempt_count": {"type": "integer", "minimum": 0},
    "pass_count": {"type": "integer", "minimum": 0},
    "total_wall_ms": {"type": "integer", "minimum": 0},
    "utility_q32": {"$ref": "q32_v1.jsonschema"},
    "capacity_eff_q32": {"$ref": "q32_v1.jsonschema"},
    "pass_problem_ids": {
      "type": "array",
      "items": {"type": "string"}
    },
    "attempt_receipt_hashes": {
      "type": "array",
      "items": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
    }
  }
}
