{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis.engine/specs/v13_0/q32_v1",
  "title": "Q32 fixed-point v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "shift", "q"],
  "properties": {
    "schema_version": {"const": "q32_v1"},
    "shift": {"const": 32},
    "q": {"type": "string", "pattern": "^-?[0-9]+$"}
  }
}
