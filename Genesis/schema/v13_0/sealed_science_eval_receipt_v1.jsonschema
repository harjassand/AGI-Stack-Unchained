{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis.engine/specs/v13_0/sealed_science_eval_receipt_v1",
  "title": "Sealed science eval receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "created_utc",
    "eval_kind",
    "theory_id",
    "fit_receipt_hash",
    "dataset_receipt_hash",
    "split_receipt_hash",
    "suitepack_hash",
    "perf_policy_hash",
    "ir_policy_hash",
    "eval_report_hash",
    "stdout_hash",
    "stderr_hash",
    "exit_code",
    "network_used",
    "time_ms",
    "memory_mb"
  ],
  "properties": {
    "schema_version": {"const": "sealed_science_eval_receipt_v1"},
    "receipt_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "created_utc": {"type": "string"},
    "eval_kind": {"type": "string", "enum": ["DEV", "HELDOUT"]},
    "theory_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "fit_receipt_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "dataset_receipt_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "split_receipt_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "suitepack_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "perf_policy_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "ir_policy_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "eval_report_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "stdout_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "stderr_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "exit_code": {"type": "integer"},
    "network_used": {"type": "boolean"},
    "time_ms": {"type": "integer", "minimum": 0},
    "memory_mb": {"type": "integer", "minimum": 0}
  }
}
