{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis.engine/specs/v16_1/metasearch_eval_trace_v2",
  "title": "Metasearch eval trace row v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "seq_u64",
    "algo_label",
    "algo_seed_u64",
    "eval_kind",
    "theory_kind",
    "norm_pow_p",
    "theory_id",
    "theory_ir_hash",
    "eval_report_hash",
    "invocation_id",
    "prev_invocation_id",
    "work_cost_total",
    "dataset_manifest_hash",
    "dataset_csv_hash",
    "dataset_receipt_hash",
    "split_receipt_hash",
    "ir_policy_hash",
    "perf_policy_hash",
    "suitepack_hash",
    "fit_receipt_hash"
  ],
  "properties": {
    "schema_version": { "const": "metasearch_eval_trace_v2" },
    "seq_u64": { "type": "integer", "minimum": 0 },
    "algo_label": { "type": "string", "enum": ["baseline", "candidate"] },
    "algo_seed_u64": { "type": "integer", "minimum": 0 },
    "eval_kind": { "type": "string", "enum": ["DEV", "HELDOUT"] },
    "theory_kind": { "type": "string", "enum": ["BASELINE_CONST_VEL_V1", "BASELINE_HOOKE_CENTRAL_V1", "CANDIDATE_CENTRAL_POWERLAW_V1", "CANDIDATE_NBODY_POWERLAW_V1"] },
    "norm_pow_p": { "type": "integer", "enum": [1, 2, 3, 4] },
    "theory_id": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "theory_ir_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "eval_report_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "invocation_id": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "prev_invocation_id": { "type": "string", "pattern": "^(GENESIS|sha256:[0-9a-f]{64})$" },
    "work_cost_total": { "type": "integer", "minimum": 0 },
    "dataset_manifest_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "dataset_csv_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "dataset_receipt_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "split_receipt_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "ir_policy_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "perf_policy_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "suitepack_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "fit_receipt_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "input_rels": { "type": "object" }
  }
}
