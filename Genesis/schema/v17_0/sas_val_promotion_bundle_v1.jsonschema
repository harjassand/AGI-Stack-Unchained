{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis.engine/specs/v17_0/sas_val_promotion_bundle_v1",
  "title": "SAS VAL promotion bundle v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_id",
    "pack_hash",
    "policy_hash",
    "patch_manifest_hash",
    "decoded_trace_hash",
    "lift_ir_hash",
    "safety_receipt_hash",
    "equivalence_receipt_hash",
    "runner_binary_hash",
    "baseline_exec_backend_hash",
    "candidate_exec_backend_hash",
    "baseline_sealed_run_receipt_hash",
    "candidate_sealed_run_receipt_hash",
    "baseline_spawn_count",
    "candidate_spawn_count",
    "hotloop_report_hash",
    "val_exec_trace_head_hash",
    "baseline_benchmark_report_hash",
    "candidate_benchmark_report_hash",
    "downstream_meta_core_receipt_hash",
    "downstream_v16_1_receipt_hash",
    "meta_core_bundle_hash",
    "baseline_kernel_tree_hash",
    "candidate_kernel_tree_hash",
    "val_cycles_baseline",
    "val_cycles_candidate",
    "valcycles_gate_pass",
    "wallclock_gate_pass",
    "work_conservation_pass",
    "determinism_keys"
  ],
  "properties": {
    "schema_version": { "const": "sas_val_promotion_bundle_v1" },
    "bundle_id": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "pack_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "policy_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "patch_manifest_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "decoded_trace_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "lift_ir_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "safety_receipt_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "equivalence_receipt_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "runner_binary_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "baseline_exec_backend_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "candidate_exec_backend_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "baseline_sealed_run_receipt_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "candidate_sealed_run_receipt_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "baseline_spawn_count": { "type": "integer", "minimum": 1 },
    "candidate_spawn_count": { "type": "integer", "minimum": 1 },
    "hotloop_report_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "val_exec_trace_head_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "baseline_benchmark_report_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "candidate_benchmark_report_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "downstream_meta_core_receipt_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "downstream_v16_1_receipt_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "meta_core_bundle_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "baseline_kernel_tree_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "candidate_kernel_tree_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "val_cycles_baseline": { "type": "integer", "minimum": 0 },
    "val_cycles_candidate": { "type": "integer", "minimum": 0 },
    "valcycles_gate_pass": { "type": "boolean" },
    "wallclock_gate_pass": { "type": "boolean" },
    "work_conservation_pass": { "type": "boolean" },
    "determinism_keys": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "val_patch_id",
        "val_decoded_trace_hash",
        "val_lift_ir_hash",
        "val_safety_receipt_hash",
        "val_exec_trace_head_hash",
        "baseline_exec_backend_hash",
        "candidate_exec_backend_hash"
      ],
      "properties": {
        "val_patch_id": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "val_decoded_trace_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "val_lift_ir_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "val_safety_receipt_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "val_exec_trace_head_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "baseline_exec_backend_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "candidate_exec_backend_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      }
    }
  }
}
