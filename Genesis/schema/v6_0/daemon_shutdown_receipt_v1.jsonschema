{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis.engine/specs/v6_0/daemon_shutdown_receipt_v1",
  "title": "Daemon shutdown receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "daemon_id",
    "icore_id",
    "meta_hash",
    "tick",
    "boot_count",
    "ledger_head_hash",
    "created_utc"
  ],
  "properties": {
    "schema_version": {"const": "daemon_shutdown_receipt_v1"},
    "kind": {"const": "SHUTDOWN"},
    "daemon_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "icore_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "meta_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "tick": {"type": "integer", "minimum": 0},
    "boot_count": {"type": "integer", "minimum": 0},
    "ledger_head_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "created_utc": {"type": "string", "format": "date-time"}
  }
}
