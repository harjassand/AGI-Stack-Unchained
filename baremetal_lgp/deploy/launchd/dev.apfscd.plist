<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>dev.apfscd</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/apfscd</string>
    <string>--base-config</string><string>config/base.toml</string>
    <string>--profile-config</string><string>config/profiles/dev.toml</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>/tmp/apfscd-dev.out.log</string>
  <key>StandardErrorPath</key><string>/tmp/apfscd-dev.err.log</string>
</dict>
</plist>
