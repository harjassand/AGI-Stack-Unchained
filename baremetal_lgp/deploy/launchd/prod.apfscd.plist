<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>prod.apfscd</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/apfscd</string>
    <string>--base-config</string><string>/Library/Application Support/APFSC/config/base.toml</string>
    <string>--profile-config</string><string>/Library/Application Support/APFSC/config/profiles/prod_single_node.toml</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>/var/log/apfscd.out.log</string>
  <key>StandardErrorPath</key><string>/var/log/apfscd.err.log</string>
</dict>
</plist>
